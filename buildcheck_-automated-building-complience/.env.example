# ANALYSIS_ENGINE_KEY: Required for system analysis engine.
# Configure this via the Secrets panel in the environment UI.
ANALYSIS_ENGINE_KEY="MY_ENGINE_KEY"

# APP_URL: The URL where this applet is hosted.
# The system automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"